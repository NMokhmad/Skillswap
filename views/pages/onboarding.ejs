<%- include('../partials/header.ejs') %>
<script src="/js/onboarding.js" defer></script>
</head>

<body>
    <main class="section" style="background: linear-gradient(135deg, #f3e8f3 0%, #ffeef8 100%); min-height: 100vh;">
        <div class="container">
            
            <!-- En-tête de bienvenue -->
            <div class="box has-text-centered mb-6 p-6" style="background: linear-gradient(135deg, #30293d 0%, #5a4a6f 50%, #7d6b93 100%); border-radius: 16px; position: relative; overflow: hidden; box-shadow: 0 12px 32px rgba(48, 41, 61, 0.25);">
                
                <!-- Effet de brillance -->
                <div style="position: absolute; top: -50%; right: -50%; width: 200%; height: 200%; background: radial-gradient(circle, rgba(255,255,255,0.1) 0%, transparent 70%); pointer-events: none;"></div>
                
                <div style="position: relative; z-index: 1;">
                    <h1 class="title is-1 has-text-light has-text-weight-bold mb-2">
                        Bienvenue <%= user.firstname %> !
                    </h1>
                    <p class="subtitle is-4 has-text-light" style="opacity: 0.95;">
                        Complétez votre profil pour commencer à échanger vos compétences
                    </p>
                </div>
            </div>

            <!-- Barre de progression -->
            <div class="box mb-5 p-4" style="background-color: white; border-radius: 12px; border: 2px solid #e8dce8;">
                <div class="is-flex is-justify-content-space-between is-align-items-center mb-3">
                    <p class="has-text-weight-semibold" style="color: #30293d;">
                        <span class="icon-text">
                            <span class="icon" style="color: #6b7db3;">
                                <i class="fa-solid fa-list-check"></i>
                            </span>
                            <span>Progression du profil</span>
                        </span>
                    </p>
                    <span id="progress-text" class="tag is-medium" style="background-color: #e07b91; color: white; font-weight: bold; border-radius: 20px; padding: 0.5rem 1.5rem;">
                        0/4 étapes
                    </span>
                </div>
                <progress id="profile-progress" class="progress is-large" value="0" max="4" style="height: 12px; border-radius: 10px;"></progress>
            </div>

            <!-- Formulaire d'onboarding -->
            <form id="onboarding-form" action="/onboarding" method="POST" enctype="multipart/form-data">
                
                <div class="columns is-centered">
                    <div class="column is-10-desktop">
                        
                        <!-- Étape 1 : Photo de profil -->
                        <div class="box step-card mb-5" style="background-color: white; border-radius: 16px; border: 3px solid #e07b91; box-shadow: 0 8px 24px rgba(224, 123, 145, 0.15); transition: all 0.3s ease;">
                            <div class="is-flex is-justify-content-space-between is-align-items-start mb-4">
                                <div>
                                    <h2 class="title is-4 has-text-weight-bold mb-2" style="color: #30293d;">
                                        <span class="icon-text">
                                            <span class="icon" style="color: #e07b91; font-size: 1.5rem;">
                                                <i class="fa-solid fa-camera"></i>
                                            </span>
                                            <span>1. Photo de profil</span>
                                        </span>
                                    </h2>
                                    <p class="subtitle is-6" style="color: #7d6b93;">Ajoutez une photo pour personnaliser votre profil (optionnel)</p>
                                </div>
                                <span class="tag is-medium" style="background-color: #ffeef8; color: #e07b91; border: 2px solid #e07b91; border-radius: 20px; font-weight: 600;">
                                    Optionnel
                                </span>
                            </div>
                            
                            <div class="has-text-centered p-5">
                                <!-- Prévisualisation de l'avatar -->
                                <figure class="image is-128x128 is-inline-block mb-4">
                                    <div id="avatar-preview" style="width: 128px; height: 128px; border-radius: 50%; background: linear-gradient(135deg, #e07b91, #ff6b9d); display: flex; align-items: center; justify-content: center; border: 5px solid white; box-shadow: 0 8px 20px rgba(224, 123, 145, 0.3); position: relative; overflow: hidden;">
                                        <span class="icon is-large has-text-light" style="font-size: 3.5rem;" id="default-icon">
                                            <i class="fa-solid fa-user"></i>
                                        </span>
                                        <img id="preview-img" src="" alt="Avatar preview" style="display: none; width: 100%; height: 100%; object-fit: cover;">
                                    </div>
                                </figure>
                                
                                <div class="file has-name is-centered is-large mb-3">
                                    <label class="file-label">
                                        <input class="file-input" type="file" name="avatar" id="avatar-input" accept="image/*">
                                        <span class="file-cta" style="background-color: #e07b91; color: white; border: none; border-radius: 10px;">
                                            <span class="file-icon">
                                                <i class="fa-solid fa-upload"></i>
                                            </span>
                                            <span class="file-label has-text-weight-semibold">
                                                Choisir une photo
                                            </span>
                                        </span>
                                        <span class="file-name" id="file-name" style="border: 2px solid #e8dce8; border-radius: 10px;">
                                            Aucun fichier sélectionné
                                        </span>
                                    </label>
                                </div>
                                
                                <p class="help" style="color: #7d6b93;">
                                    <span class="icon-text">
                                        <span class="icon">
                                            <i class="fa-solid fa-info-circle"></i>
                                        </span>
                                        <span>Format accepté : JPG, PNG, GIF (max 5Mo)</span>
                                    </span>
                                </p>
                            </div>
                        </div>

                        <!-- Étape 2 : Bio -->
                        <div class="box step-card mb-5" style="background-color: white; border-radius: 16px; border: 3px solid #6b7db3; box-shadow: 0 8px 24px rgba(107, 125, 179, 0.15); transition: all 0.3s ease;">
                            <div class="is-flex is-justify-content-space-between is-align-items-start mb-4">
                                <div>
                                    <h2 class="title is-4 has-text-weight-bold mb-2" style="color: #30293d;">
                                        <span class="icon-text">
                                            <span class="icon" style="color: #6b7db3; font-size: 1.5rem;">
                                                <i class="fa-solid fa-pen-fancy"></i>
                                            </span>
                                            <span>2. Parlez-nous de vous</span>
                                        </span>
                                    </h2>
                                    <p class="subtitle is-6" style="color: #7d6b93;">Décrivez-vous en quelques mots (optionnel)</p>
                                </div>
                                <span class="tag is-medium" style="background-color: #f0f4ff; color: #6b7db3; border: 2px solid #6b7db3; border-radius: 20px; font-weight: 600;">
                                    Optionnel
                                </span>
                            </div>
                            
                            <div class="field">
                                <div class="control">
                                    <textarea class="textarea is-medium" name="bio" id="bio" rows="5" maxlength="500" placeholder="Ex: Passionné de développement web et de design, j'aime partager mes connaissances et apprendre de nouvelles compétences..." style="border: 2px solid #e8dce8; border-radius: 10px; font-size: 1rem;"></textarea>
                                </div>
                                <p class="help has-text-right" style="color: #7d6b93;">
                                    <span id="bio-count">0</span>/500 caractères
                                </p>
                            </div>
                            
                            <div class="box" style="background-color: #f0f4ff; border-radius: 12px; border: 2px solid #a8b7e5;">
                                <p class="has-text-weight-semibold" style="color: #6b7db3; font-size: 0.9rem;">
                                    <span class="icon">
                                        <i class="fa-solid fa-lightbulb"></i>
                                    </span>
                                    Conseil : Une bio accrocheuse augmente vos chances d'être contacté !
                                </p>
                            </div>
                        </div>

                        <!-- Étape 3 : Compétences existantes -->
                        <div class="box step-card mb-5" style="background-color: white; border-radius: 16px; border: 3px solid #7d6b93; box-shadow: 0 8px 24px rgba(125, 107, 147, 0.15); transition: all 0.3s ease;">
                            <div class="is-flex is-justify-content-space-between is-align-items-start mb-4">
                                <div>
                                    <h2 class="title is-4 has-text-weight-bold mb-2" style="color: #30293d;">
                                        <span class="icon-text">
                                            <span class="icon" style="color: #7d6b93; font-size: 1.5rem;">
                                                <i class="fa-solid fa-star"></i>
                                            </span>
                                            <span>3. Vos compétences</span>
                                        </span>
                                    </h2>
                                    <p class="subtitle is-6" style="color: #7d6b93;">Sélectionnez au moins une compétence que vous maîtrisez</p>
                                </div>
                                <span class="tag is-medium" style="background-color: #ff6b9d; color: white; border-radius: 20px; font-weight: 600;">
                                    <span class="icon">
                                        <i class="fa-solid fa-star"></i>
                                    </span>
                                    <span>Requis</span>
                                </span>
                            </div>
                            
                            <!-- Barre de recherche -->
                            <div class="field mb-4">
                                <div class="control has-icons-left">
                                    <input class="input is-medium" type="text" id="skill-search" placeholder="Rechercher une compétence..." style="border: 2px solid #e8dce8; border-radius: 10px;">
                                    <span class="icon is-left" style="color: #7d6b93;">
                                        <i class="fa-solid fa-search"></i>
                                    </span>
                                </div>
                            </div>
                            
                            <!-- Grille de compétences -->
                            <div class="content">
                                <p class="has-text-weight-semibold mb-3" style="color: #30293d;">Compétences disponibles :</p>
                                <div id="skills-grid" class="is-flex is-flex-wrap-wrap" style="gap: 0.75rem; max-height: 400px; overflow-y: auto; padding: 1rem; background-color: #f9f5f9; border-radius: 12px;">
                                    <!-- Les compétences seront générées ici -->
                                    <% if (skills && skills.length > 0) { %>
                                        <% skills.forEach((skill, index) => { 
                                            const colors = [
                                                { bg: '#ffa8c5', border: '#ff6b9d', text: '#8d1450' },
                                                { bg: '#a8b7e5', border: '#6b7db3', text: '#1a2f5f' },
                                                { bg: '#e8dce8', border: '#7d6b93', text: '#30293d' },
                                                { bg: '#ffd7a8', border: '#ffb366', text: '#8d4a00' }
                                            ];
                                            const color = colors[index % colors.length];
                                        %>
                                            <label class="skill-checkbox-label" style="cursor: pointer;">
                                                <input type="checkbox" name="skills[]" value="<%= skill.id %>" class="is-hidden skill-checkbox">
                                                <div class="skill-tag" data-skill-name="<%= skill.label.toLowerCase() %>" style="background-color: <%= color.bg %>; color: <%= color.text %>; border: 3px solid transparent; border-radius: 12px; padding: 0.75rem 1.25rem; font-weight: 600; transition: all 0.3s ease; user-select: none;">
                                                    <span class="icon is-small">
                                                        <i class="fa-solid <%= skill.icon %>"></i>
                                                    </span>
                                                    <span><%= skill.label %></span>
                                                    <span class="icon is-small checkmark-icon" style="display: none; margin-left: 0.5rem;">
                                                        <i class="fa-solid fa-circle-check"></i>
                                                    </span>
                                                </div>
                                            </label>
                                        <% }) %>
                                    <% } else { %>
                                        <p style="color: #7d6b93;">Aucune compétence disponible pour le moment.</p>
                                    <% } %>
                                </div>
                                
                                <div id="selected-skills-display" class="mt-4 is-hidden">
                                    <p class="has-text-weight-semibold mb-2" style="color: #30293d;">Compétences sélectionnées :</p>
                                    <div id="selected-count" class="tag is-medium" style="background-color: #7d6b93; color: white; font-weight: bold; border-radius: 20px;">
                                        0 sélectionnée(s)
                                    </div>
                                </div>
                            </div>
                        </div>

                        <!-- Étape 4 : Nouvelle compétence -->
                        <div class="box step-card mb-5" style="background-color: white; border-radius: 16px; border: 3px solid #ffa8c5; box-shadow: 0 8px 24px rgba(255, 168, 197, 0.15); transition: all 0.3s ease;">
                            <div class="is-flex is-justify-content-space-between is-align-items-start mb-4">
                                <div>
                                    <h2 class="title is-4 has-text-weight-bold mb-2" style="color: #30293d;">
                                        <span class="icon-text">
                                            <span class="icon" style="color: #ff6b9d; font-size: 1.5rem;">
                                                <i class="fa-solid fa-plus-circle"></i>
                                            </span>
                                            <span>4. Proposer une nouvelle compétence</span>
                                        </span>
                                    </h2>
                                    <p class="subtitle is-6" style="color: #7d6b93;">Votre compétence n'est pas dans la liste ? Proposez-la ! (optionnel)</p>
                                </div>
                                <span class="tag is-medium" style="background-color: #fff5f7; color: #ff6b9d; border: 2px solid #ff6b9d; border-radius: 20px; font-weight: 600;">
                                    Optionnel
                                </span>
                            </div>
                            
                            <div class="field">
                                <label class="label" style="color: #30293d; font-weight: 600;">
                                    <span class="icon-text">
                                        <span class="icon" style="color: #ff6b9d;">
                                            <i class="fa-solid fa-tag"></i>
                                        </span>
                                        <span>Nom de la compétence</span>
                                    </span>
                                </label>
                                <div class="control has-icons-left">
                                    <input class="input is-medium" type="text" name="new_skill" id="new-skill" placeholder="Ex: Photographie culinaire, Arduino, Origami..." maxlength="50" style="border: 2px solid #e8dce8; border-radius: 10px;">
                                    <span class="icon is-left" style="color: #ff6b9d;">
                                        <i class="fa-solid fa-sparkles"></i>
                                    </span>
                                </div>
                                <p class="help" style="color: #7d6b93;">Cette compétence sera soumise pour validation avant d'être ajoutée au catalogue</p>
                            </div>
                        </div>

                        <!-- Boutons d'action -->
                        <div class="box has-text-centered p-5" style="background: linear-gradient(135deg, #ffeef8 0%, #f9f5f9 100%); border-radius: 16px; border: 3px dashed #e07b91;">
                            <div class="buttons is-centered">
                                <button type="submit" id="complete-btn" class="button is-large" style="background-color: #30293d; color: white; border: none; border-radius: 12px; font-weight: 600; padding: 1.5rem 3rem; transition: all 0.3s ease;" disabled>
                                    <span class="icon">
                                        <i class="fa-solid fa-check-circle"></i>
                                    </span>
                                    <span>Terminer et explorer SkillSwap</span>
                                </button>
                            </div>
                            
                            <div class="mt-4">
                                <a href="/skills" class="button is-medium is-text" style="color: #7d6b93; font-weight: 600;">
                                    <span class="icon">
                                        <i class="fa-solid fa-clock"></i>
                                    </span>
                                    <span>Je compléterai mon profil plus tard</span>
                                </a>
                            </div>
                            
                            <p class="help mt-3" style="color: #7d6b93;">
                                <span class="icon-text">
                                    <span class="icon">
                                        <i class="fa-solid fa-info-circle"></i>
                                    </span>
                                    <span>Vous devez sélectionner au moins une compétence pour continuer</span>
                                </span>
                            </p>
                        </div>

                    </div>
                </div>
                
            </form>
            
        </div>
    </main>
    <%- include('../partials/footer.ejs') %>
</body>
</html>