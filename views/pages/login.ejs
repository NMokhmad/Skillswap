<%- include('../partials/header.ejs') %>

<style>
    body {
        background-color: #f3e8f3;
    }

    /* Container de la page */
    .login-section {
        min-height: calc(100vh - 200px);
        display: flex;
        align-items: center;
        padding: 3rem 1.5rem;
    }

    /* Carte principale avec gradient border */
    .login-card {
        background: white;
        border-radius: 24px;
        box-shadow: 0 8px 32px rgba(48, 41, 61, 0.15);
        overflow: hidden;
        position: relative;
        border: 3px solid transparent;
        background-clip: padding-box;
    }

    .login-card::before {
        content: '';
        position: absolute;
        top: 0;
        left: 0;
        right: 0;
        bottom: 0;
        border-radius: 24px;
        padding: 3px;
        background: linear-gradient(135deg, #6b7db3, #ffd700, #ff6b9d);
        -webkit-mask: linear-gradient(#fff 0 0) content-box, linear-gradient(#fff 0 0);
        -webkit-mask-composite: xor;
        mask-composite: exclude;
        pointer-events: none;
    }

    /* En-tête avec gradient */
    .login-header {
        background: linear-gradient(135deg, #30293d, #5a4a6f, #7d6b93);
        padding: 2.5rem;
        text-align: center;
        position: relative;
        overflow: hidden;
    }

    .login-header::before {
        content: '';
        position: absolute;
        top: -50%;
        left: -50%;
        width: 200%;
        height: 200%;
        background: radial-gradient(circle, rgba(107, 125, 179, 0.15) 0%, transparent 70%);
        animation: rotate 15s linear infinite;
    }

    @keyframes rotate {
        0% { transform: rotate(0deg); }
        100% { transform: rotate(360deg); }
    }

    .login-header .icon-circle {
        width: 80px;
        height: 80px;
        background: linear-gradient(135deg, #6b7db3, #a8b7e5);
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        margin: 0 auto 1rem;
        box-shadow: 0 8px 24px rgba(107, 125, 179, 0.3);
        position: relative;
        z-index: 1;
    }

    .login-header .title {
        color: white;
        font-weight: 700;
        font-size: 2rem;
        margin-bottom: 0.5rem;
        position: relative;
        z-index: 1;
    }

    .login-header .subtitle {
        color: #a8b7e5;
        font-size: 1rem;
        position: relative;
        z-index: 1;
    }

    /* Corps du formulaire */
    .login-body {
        padding: 2.5rem;
    }

    /* Message d'erreur global */
    .error-notification {
        background: linear-gradient(135deg, #e07b91, #ff6b9d);
        color: white;
        border-radius: 12px;
        padding: 1rem;
        margin-bottom: 1.5rem;
        border: none;
        box-shadow: 0 4px 12px rgba(224, 123, 145, 0.3);
        display: flex;
        align-items: center;
        gap: 0.75rem;
        animation: slideDown 0.4s ease-out;
    }

    @keyframes slideDown {
        from {
            opacity: 0;
            transform: translateY(-10px);
        }
        to {
            opacity: 1;
            transform: translateY(0);
        }
    }

    .error-notification .icon {
        font-size: 1.5rem;
    }

    /* Champs du formulaire */
    .field {
        margin-bottom: 1.5rem;
    }

    .label {
        color: #30293d;
        font-weight: 600;
        margin-bottom: 0.5rem;
        font-size: 0.95rem;
    }

    .input {
        border: 2px solid #e0e0e0;
        border-radius: 12px;
        padding: 0.75rem 1rem;
        font-size: 1rem;
        transition: all 0.3s ease;
        background-color: #fafafa;
    }

    .input:focus {
        border-color: #6b7db3;
        background-color: white;
        box-shadow: 0 0 0 3px rgba(107, 125, 179, 0.1);
    }

    .input::placeholder {
        color: #bbb;
    }

    /* Icônes dans les inputs */
    .control.has-icons-left .input {
        padding-left: 2.75rem;
    }

    .control.has-icons-left .icon {
        height: 100%;
        width: 2.75rem;
        color: #6b7db3;
    }

    /* Lien "Mot de passe oublié" */
    .forgot-password {
        text-align: right;
        margin-top: -0.75rem;
        margin-bottom: 1.5rem;
    }

    .forgot-password a {
        color: #6b7db3;
        font-size: 0.9rem;
        text-decoration: none;
        transition: color 0.3s ease;
    }

    .forgot-password a:hover {
        color: #ff6b9d;
        text-decoration: underline;
    }

    /* Bouton de connexion */
    .btn-login {
        background: linear-gradient(135deg, #6b7db3, #a8b7e5);
        border: none;
        border-radius: 12px;
        color: white;
        font-weight: 700;
        font-size: 1.1rem;
        padding: 1rem;
        width: 100%;
        cursor: pointer;
        transition: all 0.3s ease;
        box-shadow: 0 6px 20px rgba(107, 125, 179, 0.3);
        text-transform: uppercase;
        letter-spacing: 0.5px;
    }

    .btn-login:hover {
        transform: translateY(-3px);
        box-shadow: 0 8px 24px rgba(107, 125, 179, 0.4);
    }

    .btn-login:active {
        transform: translateY(-1px);
    }

    /* Séparateur "OU" */
    .divider {
        display: flex;
        align-items: center;
        text-align: center;
        margin: 1.5rem 0;
    }

    .divider::before,
    .divider::after {
        content: '';
        flex: 1;
        border-bottom: 2px solid #f0f0f0;
    }

    .divider span {
        padding: 0 1rem;
        color: #999;
        font-weight: 600;
        font-size: 0.9rem;
    }

    /* Lien d'inscription */
    .register-link {
        text-align: center;
        margin-top: 1.5rem;
        padding-top: 1.5rem;
        border-top: 2px solid #f0f0f0;
        color: #666;
    }

    .register-link a {
        color: #ff6b9d;
        font-weight: 600;
        text-decoration: none;
        transition: color 0.3s ease;
    }

    .register-link a:hover {
        color: #e07b91;
        text-decoration: underline;
    }

    /* Badge "Bon retour" */
    .welcome-badge {
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 0.5rem;
        background: rgba(255, 215, 0, 0.1);
        padding: 0.75rem;
        border-radius: 12px;
        margin-bottom: 1.5rem;
        border: 2px solid rgba(255, 215, 0, 0.2);
    }

    .welcome-badge .icon {
        color: #ffd700;
        font-size: 1.2rem;
    }

    .welcome-badge span {
        color: #30293d;
        font-size: 0.95rem;
        font-weight: 600;
    }

    /* Responsive */
    @media screen and (max-width: 768px) {
        .login-header {
            padding: 2rem 1.5rem;
        }

        .login-header .title {
            font-size: 1.75rem;
        }

        .login-body {
            padding: 2rem 1.5rem;
        }
    }
</style>
</head>

<body>
    <%- include('../partials/navbar.ejs') %>
    
    <section class="login-section">
        <div class="container">
            <div class="columns is-centered">
                <div class="column is-5-desktop is-6-tablet is-12-mobile">
                    <div class="login-card">
                        <!-- En-tête avec gradient -->
                        <div class="login-header">
                            <div class="icon-circle">
                                <span class="icon is-large">
                                    <i class="fas fa-sign-in-alt fa-2x" style="color: white;"></i>
                                </span>
                            </div>
                            <h1 class="title">Bon retour !</h1>
                            <p class="subtitle">Connectez-vous à votre compte SkillSwap</p>
                        </div>

                        <!-- Corps du formulaire -->
                        <div class="login-body">
                            <!-- Badge de bienvenue -->
                            <div class="welcome-badge">
                                <span class="icon">
                                    <i class="fas fa-star"></i>
                                </span>
                                <span>Ravis de vous revoir parmi nous !</span>
                            </div>

                            <!-- Message d'erreur -->
                            <% if (typeof error !== 'undefined' && error) { %>
                                <div class="error-notification">
                                    <span class="icon">
                                        <i class="fas fa-exclamation-triangle"></i>
                                    </span>
                                    <div>
                                        <strong>Erreur de connexion</strong><br>
                                        <%= error %>
                                    </div>
                                </div>
                            <% } %>

                            <!-- Formulaire -->
                            <form action="/login" method="POST">
                                <!-- Email -->
                                <div class="field">
                                    <label class="label">
                                        <span class="icon is-small" style="color: #6b7db3;">
                                            <i class="fas fa-envelope"></i>
                                        </span>
                                        Email
                                    </label>
                                    <div class="control has-icons-left">
                                        <input class="input" type="email" name="email" placeholder="votre.email@exemple.com" required>
                                        <span class="icon is-left">
                                            <i class="fas fa-envelope"></i>
                                        </span>
                                    </div>
                                </div>

                                <!-- Mot de passe -->
                                <div class="field">
                                    <label class="label">
                                        <span class="icon is-small" style="color: #a8b7e5;">
                                            <i class="fas fa-lock"></i>
                                        </span>
                                        Mot de passe
                                    </label>
                                    <div class="control has-icons-left">
                                        <input class="input" type="password" name="password" placeholder="Votre mot de passe" required>
                                        <span class="icon is-left">
                                            <i class="fas fa-lock"></i>
                                        </span>
                                    </div>
                                </div>

                                <!-- Mot de passe oublié -->
                                <div class="forgot-password">
                                    <a href="/forgot-password">
                                        <span class="icon is-small">
                                            <i class="fas fa-question-circle"></i>
                                        </span>
                                        Mot de passe oublié ?
                                    </a>
                                </div>

                                <!-- Bouton de connexion -->
                                <div class="field" style="margin-top: 2rem;">
                                    <button type="submit" class="btn-login">
                                        <span class="icon">
                                            <i class="fas fa-arrow-right"></i>
                                        </span>
                                        <span>Se connecter</span>
                                    </button>
                                </div>
                            </form>

                            <!-- Séparateur -->
                            <div class="divider">
                                <span>OU</span>
                            </div>

                            <!-- Lien vers l'inscription -->
                            <div class="register-link">
                                <p>Vous n'avez pas encore de compte ? <a href="/register">Créez-en un maintenant</a></p>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <%- include('../partials/footer.ejs') %>
</body>
</html>