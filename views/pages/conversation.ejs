<%- include('../partials/header.ejs') %>
<script src="https://kit.fontawesome.com/626daf36fc.js" crossorigin="anonymous"></script>
</head>

<body>
<%- include('../partials/navbar.ejs') %>

<main class="section" style="background: linear-gradient(135deg, #f3e8f3 0%, #ffeef8 100%); min-height: 80vh;">
    <div class="container">
        <div class="columns is-centered">
            <div class="column is-8">

                <!-- En-tête de la conversation -->
                <div class="box mb-4" style="border-radius: 16px; border: 2px solid #7d6b93;">
                    <div class="is-flex is-align-items-center">
                        <a href="/messages" class="mr-4" style="color: #7d6b93;">
                            <span class="icon is-medium">
                                <i class="fas fa-arrow-left fa-lg"></i>
                            </span>
                        </a>
                        <div style="width: 48px; height: 48px; border-radius: 50%; background: linear-gradient(135deg, #7d6b93, #5a4a6f); display: flex; align-items: center; justify-content: center; flex-shrink: 0;">
                            <span style="color: white; font-weight: 700;">
                                <%= otherUser.firstname.charAt(0).toUpperCase() %><%= otherUser.lastname.charAt(0).toUpperCase() %>
                            </span>
                        </div>
                        <div class="ml-3">
                            <a href="/talents/<%= otherUser.id %>" class="has-text-weight-bold" style="color: #30293d; font-size: 1.1rem;">
                                <%= otherUser.firstname %> <%= otherUser.lastname %>
                            </a>
                        </div>
                    </div>
                </div>

                <!-- Messages -->
                <div class="box" id="messages-container" style="border-radius: 16px; max-height: 500px; overflow-y: auto; padding: 1.5rem;">
                    <% if (messages.length === 0) { %>
                        <p class="has-text-centered has-text-grey" style="padding: 2rem;">
                            Aucun message. Commencez la conversation !
                        </p>
                    <% } %>

                    <% messages.forEach(msg => { %>
                        <% const isMine = msg.sender_id === currentUserId; %>
                        <div class="mb-4" style="display: flex; justify-content: <%= isMine ? 'flex-end' : 'flex-start' %>;">
                            <div style="max-width: 70%; padding: 0.75rem 1rem; border-radius: 16px; <%= isMine ?
                                'background: linear-gradient(135deg, #7d6b93, #5a4a6f); color: white; border-bottom-right-radius: 4px;' :
                                'background: white; color: #30293d; border: 2px solid #e8dce8; border-bottom-left-radius: 4px;' %>">
                                <p style="line-height: 1.5; word-break: break-word;"><%= msg.content %></p>
                                <p class="is-size-7 mt-1" style="opacity: 0.7; text-align: right;">
                                    <%= new Date(msg.created_at).toLocaleTimeString('fr-FR', { hour: '2-digit', minute: '2-digit' }) %>
                                </p>
                            </div>
                        </div>
                    <% }) %>
                </div>

                <!-- Formulaire d'envoi -->
                <div class="box mt-4" style="border-radius: 16px; border: 2px solid #e07b91;">
                    <form action="/messages/<%= otherUser.id %>" method="POST">
                        <div class="field has-addons message-field">
                            <div class="control is-expanded">
                                <input class="input is-medium" type="text" name="content" placeholder="Écrire un message..." required autocomplete="off" style="border-radius: 12px; border: 2px solid #e8dce8;">
                            </div>
                            <div class="control">
                                <button type="submit" class="button is-medium" style="background-color: #e07b91; color: white; border: none; border-radius: 12px; font-weight: 600; margin-left: 0.5rem;">
                                    <span class="icon">
                                        <i class="fas fa-paper-plane"></i>
                                    </span>
                                </button>
                            </div>
                        </div>
                    </form>
                </div>

            </div>
        </div>
    </div>
</main>

<script>
    // Auto-scroll vers le dernier message
    const container = document.getElementById('messages-container');
    if (container) {
        container.scrollTop = container.scrollHeight;
    }
</script>

<%- include('../partials/footer.ejs') %>
</body>
</html>
